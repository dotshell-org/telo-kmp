<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Foreground service permissions required for WorkManager background tasks -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Exact alarm permissions for widget scheduling -->
    <!-- Required for real-time public transport information updates -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" 
        tools:ignore="UnusedAttribute" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" 
        android:maxSdkVersion="32"
        tools:ignore="ExactAlarmPolicy,UnusedAttribute" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground service types required for Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:name=".PeloApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pelo"
        tools:ignore="RemoveWorkManagerInitializer">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Pelo"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.pelotcl.app.generic.service.NavigationModeForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Widget configuration activity -->
        <activity
            android:name="com.pelotcl.app.generic.widget.ui.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.Pelo">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Reschedule widget alarms after device reboot -->
        <receiver
            android:name="com.pelotcl.app.generic.widget.receiver.WidgetBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Widget alarm refresh receiver -->
        <receiver
            android:name="com.pelotcl.app.generic.widget.receiver.WidgetAlarmReceiver"
            android:exported="false" />



        <!-- Widget receiver -->
        <receiver
            android:name="com.pelotcl.app.generic.widget.receiver.PeloWidgetReceiver"
            android:label="@string/widget_label_all_lines_minutes"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/pelo_widget_all_lines_minutes_info" />
        </receiver>

        <receiver
            android:name="com.pelotcl.app.generic.widget.receiver.PeloWidgetClockAllLinesReceiver"
            android:label="@string/widget_label_all_lines_clock"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/pelo_widget_all_lines_clock_info" />
        </receiver>

        <receiver
            android:name="com.pelotcl.app.generic.widget.receiver.PeloWidgetLineMinutesReceiver"
            android:label="@string/widget_label_line_minutes"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/pelo_widget_line_minutes_info" />
        </receiver>

        <receiver
            android:name="com.pelotcl.app.generic.widget.receiver.PeloWidgetLineClockReceiver"
            android:label="@string/widget_label_line_clock"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/pelo_widget_line_clock_info" />
        </receiver>
    </application>

</manifest>
